                                        <Button x:Name="CommonPromptNextPageButton" Style="{StaticResource FluentButtonStyle}" Content="下一页" MinHeight="32" Padding="10,4" Click="CommonPromptNextPageButton_Click" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                                        <Button Style="{StaticResource FluentButtonStyle}" Content="导入 JSON" Click="ImportCommonPromptsJsonButton_Click" />
                                        <Button Style="{StaticResource FluentButtonStyle}" Content="导出 JSON" Click="ExportCommonPromptsJsonButton_Click" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Grid x:Name="ModelsPage" Visibility="Collapsed">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="14">
                            <TextBlock Text="模型管理" Style="{StaticResource PageTitleStyle}" />
                            <CheckBox x:Name="ModelEnabledBox" Content="启用 OpenAI-compatible 模型优化" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />
                            <CheckBox x:Name="ModelExternalRequestsEnabledBox" Content="允许向模型 Provider 外发文本" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />
                            <CheckBox x:Name="ModelImageExternalRequestsEnabledBox" Content="允许显式附图时向多模态模型外发图片" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="320" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="ProviderPresetBox" Header="提供商预设" PlaceholderText="选择常用 Provider 自动填充 Base URL 和推荐模型" MinWidth="300" SelectionChanged="ProviderPresetBox_SelectionChanged">
                                    <ComboBoxItem Tag="custom" Content="自定义 / OpenAI-compatible" />
                                    <ComboBoxItem Tag="openai" Content="OpenAI" />
                                    <ComboBoxItem Tag="deepseek" Content="DeepSeek" />
                                    <ComboBoxItem Tag="glm" Content="GLM / 智谱" />
                                    <ComboBoxItem Tag="claude" Content="Claude / Anthropic" />
                                    <ComboBoxItem Tag="gemini" Content="Gemini / Google" />
                                    <ComboBoxItem Tag="minimax" Content="MiniMax" />
                                    <ComboBoxItem Tag="doubao" Content="豆包 / 火山方舟" />
                                    <ComboBoxItem Tag="kimi" Content="Kimi / Moonshot" />
                                </ComboBox>
                                <TextBox Grid.Column="1" x:Name="BaseUrlBox" Header="Base URL" PlaceholderText="https://api.example.com/v1" TextChanged="ModelEndpointInput_TextChanged" LostFocus="SettingsControl_LostFocus" />
                            </Grid>
                            <PasswordBox x:Name="ApiKeyBox" Header="API Key" PlaceholderText="保存到 Windows Credential Manager" PasswordChanged="ApiKeyBox_PasswordChanged" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ModelNameBox" Header="当前模型" PlaceholderText="gpt-4.1-mini / qwen-vl / local model" LostFocus="SettingsControl_LostFocus" />
                                <ComboBox Grid.Column="1" x:Name="DetectedModelBox" Header="可用模型" PlaceholderText="填写 URL 和 API Key 后自动刷新" MinWidth="280" SelectionChanged="DetectedModelBox_SelectionChanged" />
                            </Grid>
                            <TextBlock x:Name="ModelCapabilityText" Text="模型标签：未检测" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                            <TextBlock x:Name="ModelProbeStatusText" Text="填写 Base URL 和 API Key 后会自动检测可用性并刷新模型列表。" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                            <TextBlock Text="修改后自动保存，标题栏会显示 Provider + 模型名称。模型生成会等待服务端返回；可用性检测会单独检查 endpoint 和错误码。" Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="SettingsPage" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled" HorizontalScrollBarVisibility="Disabled" HorizontalScrollMode="Disabled" ZoomMode="Disabled">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock Text="设置" Style="{StaticResource PageTitleStyle}" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="280" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="LanguageBox" Header="界面语言" MinWidth="240" SelectionChanged="LanguageBox_SelectionChanged">
                                        <ComboBoxItem Content="自动 / Auto" Tag="auto" />
                                        <ComboBoxItem Content="中文" Tag="zh-CN" />
                                        <ComboBoxItem Content="English" Tag="en-US" />
                                    </ComboBox>
                                    <Button Grid.Column="1" Style="{StaticResource FluentButtonStyle}" Content="挂载语言包" Click="MountLanguagePackButton_Click" VerticalAlignment="Bottom" />
                                </Grid>
                                <CheckBox x:Name="AnimationEnabledBox" Content="启用界面动画" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />
                                <TextBlock Text="关闭后页面切换、聊天气泡和提示词输出会直接显示最终内容。" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                                <TextBlock Text="全局置顶小窗口快捷键" Style="{StaticResource SectionTitleStyle}" />
                                <CheckBox x:Name="HotkeyEnabledBox" Content="启用全局快捷键呼出置顶小窗口" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <CheckBox x:Name="HotkeyCtrlBox" Content="Ctrl" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />
                                    <CheckBox x:Name="HotkeyShiftBox" Content="Shift" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />
                                    <CheckBox x:Name="HotkeyAltBox" Content="Alt" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />
                                    <CheckBox x:Name="HotkeyWinBox" Content="Win" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />
                                    <ComboBox x:Name="HotkeyKeyBox" Header="主键" Width="180" MaxDropDownHeight="360" SelectionChanged="SettingsComboBox_SelectionChanged" />
                                </StackPanel>
                                <TextBlock Text="从下拉菜单选择主键。支持 A-Z、0-9、Space、Tab、Enter、F1-F24。" Style="{StaticResource MutedTextStyle}" />
                                <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4" />
                                <CheckBox x:Name="RedactBeforeModelSendBox" Content="发送给模型前本地脱敏敏感信息" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />
                                <CheckBox x:Name="OcrEnabledBox" Content="启用本地 OCR（火眼金睛 OCR）" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />
                                <ComboBox x:Name="OcrProviderBox" Header="OCR 后端" SelectedIndex="0" MinWidth="320" SelectionChanged="SettingsComboBox_SelectionChanged">
                                    <ComboBoxItem Content="火眼金睛 OCR（默认，失败时使用 Windows Media OCR 兜底）" Tag="fire_eye_ocr" />
                                    <ComboBoxItem Content="自动兜底（火眼金睛 -> Windows Media OCR）" Tag="auto_ocr" />
                                </ComboBox>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Style="{StaticResource PrimaryActionButtonStyle}" Content="恢复默认设置" Click="RestoreDefaultSettingsButton_Click" />
                                    <Button Style="{StaticResource FluentButtonStyle}" Content="清除历史" Click="ClearHistoryButton_Click" />
                                    <Button Style="{StaticResource FluentButtonStyle}" Content="清除收藏" Click="ClearFavoritesButton_Click" />
                                    <Button Style="{StaticResource FluentButtonStyle}" Content="收起到浮窗" Click="CollapseToCompactButton_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="HelpPage" Visibility="Collapsed">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="560">
                            <Image Width="112" Height="112" Source="Assets/logo.png" Stretch="Uniform" />
                            <TextBlock Text="啊拼" Style="{StaticResource PageTitleStyle}" HorizontalAlignment="Center" />
                            <TextBlock x:Name="VersionTextBlock" Text="版本号：" Style="{StaticResource MutedTextStyle}" HorizontalAlignment="Center" />
                            <TextBlock Text="© 夏语工作室 版权所有" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="该工具的诞生离不开 ChatGPT-Shortcut、SD-Anima-Prompt-Studio、prompts.chat、Female Portrait Prompt Director Skill 开源项目以及其他开源软件。" Style="{StaticResource MutedTextStyle}" TextAlignment="Center" />
                            <Button Style="{StaticResource PrimaryActionButtonStyle}" Content="打开开源项目引用文档" Click="OpenOpenSourceReferencesButton_Click" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Grid x:Name="NarrowSidebarOverlay" Grid.Row="1" Grid.RowSpan="2" Visibility="Collapsed" Canvas.ZIndex="20">
            <Border Background="#33000000" Tapped="SidebarOverlayScrim_Tapped" />
            <Border Width="300" HorizontalAlignment="Left" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
                <StackPanel Spacing="6" Padding="16,18,12,18">
                    <Button Tag="Home" Style="{StaticResource NavButtonStyle}" Click="NavigationButton_Click" ToolTipService.ToolTip="首页">
                        <StackPanel Orientation="Horizontal" Spacing="12"><FontIcon Width="22" FontFamily="Segoe Fluent Icons" Glyph="&#xE80F;" /><TextBlock Text="首页" /></StackPanel>
                    </Button>
                    <Button Tag="History" Style="{StaticResource NavButtonStyle}" Click="NavigationButton_Click" ToolTipService.ToolTip="历史记录">
                        <StackPanel Orientation="Horizontal" Spacing="12"><FontIcon Width="22" FontFamily="Segoe Fluent Icons" Glyph="&#xE823;" /><TextBlock Text="历史记录" /></StackPanel>
                    </Button>
                    <Button Tag="Templates" Style="{StaticResource NavButtonStyle}" Click="NavigationButton_Click" ToolTipService.ToolTip="我的模板">
                        <StackPanel Orientation="Horizontal" Spacing="12"><FontIcon Width="22" FontFamily="Segoe Fluent Icons" Glyph="&#xE8F1;" /><TextBlock Text="我的模板" /></StackPanel>
                    </Button>
                    <Button Tag="Skills" Style="{StaticResource NavButtonStyle}" Click="NavigationButton_Click" ToolTipService.ToolTip="Skill 管理">
                        <StackPanel Orientation="Horizontal" Spacing="12"><FontIcon Width="22" FontFamily="Segoe Fluent Icons" Glyph="&#xE8B7;" /><TextBlock Text="Skill 管理" /></StackPanel>
                    </Button>
                    <Button Tag="OptimizationTargets" Style="{StaticResource NavButtonStyle}" Click="NavigationButton_Click" ToolTipService.ToolTip="优化目标">
                        <StackPanel Orientation="Horizontal" Spacing="12"><FontIcon Width="22" FontFamily="Segoe Fluent Icons" Glyph="&#xE7C1;" /><TextBlock Text="优化目标" /></StackPanel>
                    </Button>
                    <Button Tag="Snippets" Style="{StaticResource NavButtonStyle}" Click="NavigationButton_Click" ToolTipService.ToolTip="常用提示词">
                        <StackPanel Orientation="Horizontal" Spacing="12"><FontIcon Width="22" FontFamily="Segoe Fluent Icons" Glyph="&#xE8A5;" /><TextBlock Text="常用提示词" /></StackPanel>
                    </Button>
                    <Button Tag="Models" Style="{StaticResource NavButtonStyle}" Click="NavigationButton_Click" ToolTipService.ToolTip="模型管理">
                        <StackPanel Orientation="Horizontal" Spacing="12"><FontIcon Width="22" FontFamily="Segoe Fluent Icons" Glyph="&#xE74C;" /><TextBlock Text="模型管理" /></StackPanel>
                    </Button>
                    <Button Tag="Settings" Style="{StaticResource NavButtonStyle}" Click="NavigationButton_Click" ToolTipService.ToolTip="设置">
                        <StackPanel Orientation="Horizontal" Spacing="12"><FontIcon Width="22" FontFamily="Segoe Fluent Icons" Glyph="&#xE713;" /><TextBlock Text="设置" /></StackPanel>
                    </Button>
                    <Button Tag="Help" Style="{StaticResource NavButtonStyle}" Click="NavigationButton_Click" ToolTipService.ToolTip="关于">
                        <StackPanel Orientation="Horizontal" Spacing="12"><FontIcon Width="22" FontFamily="Segoe Fluent Icons" Glyph="&#xE946;" /><TextBlock Text="关于" /></StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="12,0,12,10" Padding="18,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
            <Grid ColumnSpacing="22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE930;" Foreground="#22C55E" />
                    <TextBlock x:Name="BottomSceneText" Text="优化目标：通用 LLM" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE774;" />
                    <TextBlock x:Name="BottomLanguageText" Text="输出语言：中英双语" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74C;" />
                    <TextBlock x:Name="BottomModelText" Text="当前模型：本地结构化" />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Visibility="Collapsed">
            <TextBox x:Name="ContextBox" AcceptsReturn="True" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Window>
