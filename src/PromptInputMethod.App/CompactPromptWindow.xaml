<Window
    x:Class="PromptInputMethod.App.CompactPromptWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="啊拼">

    <Grid Background="Transparent" AutomationProperties.Name="AI Quick Prompt Workbench">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Enter" Modifiers="Control" Invoked="SendKeyboardAccelerator_Invoked" />
            <KeyboardAccelerator Key="N" Modifiers="Control" Invoked="NewSessionKeyboardAccelerator_Invoked" />
            <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="CommandPaletteKeyboardAccelerator_Invoked" />
        </Grid.KeyboardAccelerators>
        <Grid.Resources>
            <SolidColorBrush x:Key="SettingsNavSelectedBackgroundBrush" Color="#14000000" />
            <SolidColorBrush x:Key="SettingsNavSelectedIndicatorBrush" Color="#FF0067C0" />
            <Style x:Key="MutedTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
            <Style x:Key="CardBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="20" />
            </Style>
            <Style x:Key="PanelBorderStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                <Setter Property="Padding" Value="16" />
            </Style>
            <Style x:Key="FluentButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="16,9" />
                <Setter Property="MinHeight" Value="42" />
            </Style>
            <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="MinHeight" Value="42" />
                <Setter Property="Padding" Value="14,0" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Border
                                    x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}" />
                                <Rectangle
                                    Width="3"
                                    Height="18"
                                    Margin="0,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Fill="{TemplateBinding BorderBrush}"
                                    RadiusX="2"
                                    RadiusY="2" />
                                <ContentPresenter
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}" />
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="RootBorder.Background" Value="#10000000" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="RootBorder.Background" Value="#1A000000" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="RootBorder.Opacity" Value="0.45" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="SceneChipStyle" TargetType="ToggleButton">
                <Setter Property="MinHeight" Value="40" />
                <Setter Property="Padding" Value="12,6" />
                <Setter Property="CornerRadius" Value="10" />
            </Style>
            <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="22,10" />
                <Setter Property="MinHeight" Value="44" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
            <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Width" Value="38" />
                <Setter Property="Height" Value="38" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="19" />
            </Style>
            <Style x:Key="TemplateListViewStyle" TargetType="ListView">
                <Setter Property="Padding" Value="0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="Transparent" />
            </Style>
            <Style x:Key="TemplateListViewItemStyle" TargetType="ListViewItem">
                <Setter Property="MinHeight" Value="42" />
                <Setter Property="Padding" Value="6,4" />
                <Setter Property="Margin" Value="0,1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="52" Padding="22,0,138,0" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="TopSidebarMenuButton" Visibility="Collapsed" Style="{StaticResource IconButtonStyle}" Click="TopSidebarMenuButton_Click" ToolTipService.ToolTip="菜单" AutomationProperties.Name="菜单" AccessKey="M">
                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE700;" FontSize="17" />
            </Button>
            <Image Grid.Column="1" Width="34" Height="34" Source="Assets/logo.png" Stretch="Uniform" VerticalAlignment="Center" />
            <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="0">
                <TextBlock Text="啊拼" FontSize="17" FontWeight="SemiBold" />
                <TextBlock Text="AI Quick Prompt" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
            <Button Grid.Column="3" Style="{StaticResource IconButtonStyle}" Click="CommandPaletteButton_Click" ToolTipService.ToolTip="命令面板" AutomationProperties.Name="命令面板" AccessKey="F">
                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE721;" FontSize="16" />
            </Button>
            <Button x:Name="TopModelButton" Grid.Column="4" Style="{StaticResource FluentButtonStyle}" Click="ModelMenuButton_Click" ToolTipService.ToolTip="切换模型" Padding="10,6" MinHeight="34" AutomationProperties.Name="切换模型" AccessKey="L">
                <TextBlock x:Name="TopModelText" Text="当前模型：本地结构化" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" MaxWidth="420" />
            </Button>
            <Button Grid.Column="5" Style="{StaticResource IconButtonStyle}" Click="SettingsButton_Click" ToolTipService.ToolTip="设置" AutomationProperties.Name="设置" AccessKey="S">
                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE713;" FontSize="17" />
            </Button>
        </Grid>

        <Grid x:Name="CompactShell" Grid.Row="1" Margin="44,6,44,10" RowSpacing="8" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="8" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ToggleButton x:Name="CompactWorkbenchTab" Tag="Workbench" Style="{StaticResource SceneChipStyle}" Content="提示词优化" IsChecked="True" Click="CompactTabButton_Click" />
                <ToggleButton Grid.Column="1" x:Name="CompactCommonPromptTab" Tag="CommonPrompts" Style="{StaticResource SceneChipStyle}" Content="常用提示词" Click="CompactTabButton_Click" />
            </Grid>

            <Grid x:Name="CompactWorkbenchPage" Grid.Row="1" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource CardBorderStyle}" Padding="12">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8F2;" FontSize="22" />
                            <TextBlock Grid.Column="1" Text="输入需求" Style="{StaticResource PageTitleStyle}" />
                            <Button Grid.Column="2" Style="{StaticResource FluentButtonStyle}" Click="NewSessionButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE710;" FontSize="15" />
                                    <TextBlock Text="新会话" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="3" Style="{StaticResource IconButtonStyle}" Click="ExpandButton_Click" ToolTipService.ToolTip="展开工作台">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE740;" FontSize="16" />
                            </Button>
                            <Button Grid.Column="4" Style="{StaticResource IconButtonStyle}" Click="SettingsButton_Click" ToolTipService.ToolTip="设置">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE713;" FontSize="17" />
                            </Button>
                        </Grid>

                        <ScrollViewer Grid.Row="1" MaxHeight="124" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="CompactChatMessagesPanel" Spacing="8" Padding="4,0,4,2">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="54" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34" Height="34" CornerRadius="17" Background="{ThemeResource ControlFillColorSecondaryBrush}">
                                        <Image Source="Assets/logo.png" Width="28" Height="28" Stretch="Uniform" />
                                    </Border>
                                    <Border Grid.Column="1" CornerRadius="12" Padding="12,9" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                        <TextBlock Text="好的，把你想优化的需求发给我；我会边聊天边整理成下面的当前提示词和优化后提示词。" TextWrapping="Wrap" />
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="10:18" Style="{StaticResource MutedTextStyle}" VerticalAlignment="Center" FontSize="12" />
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="2" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="10">
                            <Grid RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <TextBox
                                        x:Name="InputBox"
                                        AcceptsReturn="True"
                                        BorderThickness="0"
                                        MinHeight="72"
                                        MaxHeight="150"
                                        MaxLength="1000"
                                        Padding="6,4,6,24"
                                        PlaceholderText="继续补充你想修改的需求..."
                                        Paste="InputTextBox_Paste"
                                        TextChanged="InputBox_TextChanged"
                                        TextWrapping="Wrap"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                    <TextBlock x:Name="InputCountText" Text="0 / 1000" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,2" Style="{StaticResource MutedTextStyle}" />
                                </Grid>

                                <Border x:Name="CompactImagePreview" Grid.Row="1" Visibility="Collapsed" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="10" Padding="8">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Image x:Name="CompactImagePreviewImage" Width="72" Height="48" Stretch="UniformToFill" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="附件托盘" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock x:Name="CompactImagePreviewText" Text="已附图" FontWeight="SemiBold" />
                                            <TextBlock Text="粘贴图片、OCR 图片或选择图片后会作为模型附图" Style="{StaticResource MutedTextStyle}" />
                                        </StackPanel>
                                        <Button Grid.Column="2" Style="{StaticResource IconButtonStyle}" Click="ClearAttachmentButton_Click" ToolTipService.ToolTip="移除附件">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE711;" FontSize="14" />
                                        </Button>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="2" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Style="{StaticResource FluentButtonStyle}" ToolTipService.ToolTip="上传图片">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xEB9F;" FontSize="16" />
                                            <TextBlock Text="上传图片" />
                                        </StackPanel>
                                        <Button.Flyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="OCR 图片" Click="ReadImageOcrButton_Click" />
                                                <MenuFlyoutItem Text="直发大模型" Click="AttachModelImageButton_Click" />
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                    <Button Grid.Column="1" Style="{StaticResource FluentButtonStyle}" ToolTipService.ToolTip="截图">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE722;" FontSize="16" />
                                            <TextBlock Text="截图" />
                                        </StackPanel>
                                        <Button.Flyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="OCR 截图" Click="ReadRegionOcrButton_Click" />
                                                <MenuFlyoutItem Text="直发大模型" Click="AttachScreenshotToModelButton_Click" />
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                    <ToggleButton x:Name="CompactDeepThinkingToggle" Grid.Column="2" Style="{StaticResource SceneChipStyle}" Content="深度思考" Checked="DeepThinkingToggle_Changed" Unchecked="DeepThinkingToggle_Changed" ToolTipService.ToolTip="按当前内置 Provider / 模型标签启用原生深度思考；不支持时显示提示词式思考摘要。" />
                                    <TextBlock Grid.Column="3" x:Name="CompactChatStatusText" Text="可连续补充需求；点“新会话”切换优化目标。" FontSize="12" TextTrimming="CharacterEllipsis" Style="{StaticResource MutedTextStyle}" VerticalAlignment="Center" />
                                    <Button Grid.Column="4" Style="{StaticResource PrimaryActionButtonStyle}" Click="ChatSendButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="9">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE724;" FontSize="18" />
                                            <TextBlock Text="发送" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="12">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7C1;" FontSize="18" />
                            <TextBlock Text="优化目标" Style="{StaticResource SectionTitleStyle}" />
                        </StackPanel>
                        <ComboBox x:Name="CompactOptimizationCategoryBox" Grid.Row="1" Header="大类" HorizontalAlignment="Stretch" SelectionChanged="CompactOptimizationCategoryBox_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="1">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource MutedTextStyle}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ComboBox x:Name="CompactModeBox" Grid.Row="2" Header="目标" HorizontalAlignment="Stretch" SelectionChanged="CompactModeBox_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="1" MinWidth="220">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource MutedTextStyle}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ComboBox x:Name="CompactTemplateBox" Grid.Row="3" Header="模板" PlaceholderText="选择目标对应模板" HorizontalAlignment="Stretch" SelectionChanged="CompactTemplateBox_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="1">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Source}" Style="{StaticResource MutedTextStyle}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ComboBox x:Name="CompactSkillBox" Grid.Row="4" Header="Skill" PlaceholderText="选择 Skill（可选）" HorizontalAlignment="Stretch" SelectionChanged="CompactSkillBox_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="1">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource MutedTextStyle}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <StackPanel Grid.Row="5" Spacing="4" VerticalAlignment="Bottom">
                            <TextBlock x:Name="SceneText" Text="优化目标：通用 LLM" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                            <TextBlock x:Name="StatusText" FontSize="12" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="1" ColumnSpacing="12" MinHeight="210">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource CardBorderStyle}" Padding="12">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="中文提示词" Style="{StaticResource SectionTitleStyle}" />
                            <Button Grid.Column="1" Style="{StaticResource FluentButtonStyle}" Content="复制" Click="CopyButton_Click" />
                            <Button Grid.Column="2" Style="{StaticResource FluentButtonStyle}" Content="收藏" Click="FavoriteChinesePromptButton_Click" />
                        </Grid>
                        <Border Grid.Row="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12">
                            <Grid>
                                <TextBox
                                    x:Name="OutputBox"
                                    AcceptsReturn="True"
                                    BorderThickness="0"
                                    MaxLength="12000"
                                    MinHeight="136"
                                    Padding="16,14,16,32"
                                    PlaceholderText="中文优化 Prompt 会显示在这里"
                                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                                    TextChanged="OutputBox_TextChanged"
                                    VerticalAlignment="Stretch"
                                    TextWrapping="Wrap" />
                                <TextBlock x:Name="OutputCountText" Text="0 / 12000" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,16,10" Style="{StaticResource MutedTextStyle}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="12">
                    <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="英语提示词" Style="{StaticResource SectionTitleStyle}" />
                            <Button x:Name="CompactFieldCopyPrimaryButton" Grid.Column="1" Style="{StaticResource FluentButtonStyle}" Content="正向" Click="CopyComfyPositiveButton_Click" ToolTipService.ToolTip="复制当前目标的核心字段" />
                            <Button x:Name="CompactFieldCopyConstraintButton" Grid.Column="2" Style="{StaticResource FluentButtonStyle}" Content="反向" Click="CopyComfyNegativeButton_Click" ToolTipService.ToolTip="复制当前目标的约束字段" />
                            <Button x:Name="CompactFieldCopyParameterButton" Grid.Column="3" Style="{StaticResource FluentButtonStyle}" Content="参数" Click="CopyComfyParametersButton_Click" ToolTipService.ToolTip="复制当前目标的参数字段" />
                            <Button Grid.Column="4" Style="{StaticResource FluentButtonStyle}" Content="复制" Click="CopyEnglishButton_Click" />
                            <Button Grid.Column="5" Style="{StaticResource FluentButtonStyle}" Content="收藏" Click="FavoriteEnglishPromptButton_Click" />
                        </Grid>
                        <Border Grid.Row="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12">
                            <Grid>
                                <TextBox
                                    x:Name="CompactEnglishOutputBox"
                                    AcceptsReturn="True"
                                    BorderThickness="0"
                                    MaxLength="12000"
                                    MinHeight="136"
                                    Padding="16,14,16,32"
                                    PlaceholderText="English prompt will appear here"
                                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                                    TextChanged="CompactEnglishOutputBox_TextChanged"
                                    VerticalAlignment="Stretch"
                                    TextWrapping="Wrap" />
                                <TextBlock x:Name="CompactEnglishCountText" Text="Words: 0" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,16,10" Style="{StaticResource MutedTextStyle}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
            </Grid>

            <Grid x:Name="CompactCommonPromptPage" Grid.Row="1" Visibility="Collapsed">
                <Border Style="{StaticResource CardBorderStyle}" Padding="16">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8A5;" FontSize="22" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="常用提示词" Style="{StaticResource PageTitleStyle}" />
                                <TextBlock Text="左键复制，右键编辑或删除。" Style="{StaticResource MutedTextStyle}" />
