<Window
    x:Class="PromptInputMethod.App.RegionSelectionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="选择 OCR 区域">

    <Grid
        x:Name="RootGrid"
        Background="#99000000"
        PointerPressed="RootGrid_PointerPressed"
        PointerMoved="RootGrid_PointerMoved"
        PointerReleased="RootGrid_PointerReleased">
        <Image x:Name="ScreenshotImage" Stretch="Fill" Opacity="0.72" />
        <Canvas>
            <Rectangle
                x:Name="SelectionRectangle"
                Stroke="#FF4CC2FF"
                StrokeThickness="2"
                Fill="#334CC2FF"
                Visibility="Collapsed" />
        </Canvas>
        <Border
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Margin="0,24,0,0"
            Padding="14,8"
            Background="#CC202020"
            CornerRadius="8">
            <TextBlock Text="拖选要 OCR 的区域，Esc 取消" Foreground="White" />
        </Border>
    </Grid>
</Window>
