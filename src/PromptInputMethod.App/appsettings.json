{
  "model": {
    "enabled": false,
    "baseUrl": "https://api.example.com/v1",
    "model": "gpt-4.1-mini",
    "credentialTargetName": "PromptInputMethod/OpenAICompatibleApiKey",
    "timeoutSeconds": 30
  },
  "ocr": {
    "preferredProvider": "fire_eye_ocr",
    "timeoutSeconds": 15
  },
  "ui": {
    "languageCode": "auto",
    "enableAnimations": true
  },
  "privacy": {
    "ocrEnabled": true,
    "modelExternalRequestsEnabled": true,
    "modelImageExternalRequestsEnabled": false,
    "confirmBeforeModelSend": true,
    "redactBeforeModelSend": true
  }
}
