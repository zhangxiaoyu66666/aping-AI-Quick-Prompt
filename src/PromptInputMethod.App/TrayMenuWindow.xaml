<Window
    x:Class="PromptInputMethod.App.TrayMenuWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="啊拼">

    <Grid Width="248" Height="178" Padding="6" Background="Transparent">
        <Grid.Resources>
            <SolidColorBrush x:Key="TrayGlassBrush" Color="#38FFFFFF" />
            <SolidColorBrush x:Key="TrayGlassIconBrush" Color="#66FFFFFF" />
            <SolidColorBrush x:Key="TrayGlassStrokeBrush" Color="#66FFFFFF" />
            <SolidColorBrush x:Key="TrayGlassDividerBrush" Color="#33FFFFFF" />
            <Style x:Key="TrayMenuButtonStyle" TargetType="Button">
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="12,9" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="Transparent" />
            </Style>
            <Style x:Key="TrayMenuMutedTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="FontSize" Value="12" />
            </Style>
        </Grid.Resources>

        <Border
            Padding="10"
            Background="{StaticResource TrayGlassBrush}"
            BorderBrush="{StaticResource TrayGlassStrokeBrush}"
            BorderThickness="1"
            CornerRadius="12">
            <StackPanel Spacing="8">
                <Grid ColumnSpacing="10" Margin="2,0,2,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="32"
                        Height="32"
                        CornerRadius="8"
                        Background="{StaticResource TrayGlassIconBrush}">
                        <Image Source="Assets/logo.png" Width="24" Height="24" Stretch="Uniform" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="啊拼" FontWeight="SemiBold" />
                        <TextBlock Text="正在后台运行" Style="{StaticResource TrayMenuMutedTextStyle}" />
                    </StackPanel>
                </Grid>

                <Rectangle Height="1" Fill="{StaticResource TrayGlassDividerBrush}" />

                <Button Style="{StaticResource TrayMenuButtonStyle}" Click="OpenButton_Click">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8A7;" FontSize="15" />
                        <TextBlock Grid.Column="1" Text="打开工作台" VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <Button Style="{StaticResource TrayMenuButtonStyle}" Click="ExitButton_Click">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8BB;" FontSize="15" />
                        <TextBlock Grid.Column="1" Text="退出应用" VerticalAlignment="Center" />
                    </Grid>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
